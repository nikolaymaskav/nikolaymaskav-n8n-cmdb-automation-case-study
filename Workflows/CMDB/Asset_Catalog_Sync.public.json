    {
      "parameters": {
        "jsCode": "// ============================================================\n// Asset Catalog Sync ,  Parse + Dedup, no filtering\n// Uses n8n binary helper for large files (18+ MB CSVs)\n// ============================================================\n\n// Load binary CSV with n8n's helper (handles large files)\nconst binaryBuffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst csvText = binaryBuffer.toString('utf-8');\n\nif (!csvText || csvText.length < 10) {\n    throw new Error(`CSV content too small: ${csvText?.length ?? 0} chars`);\n}\n\n// CSV line parser with quoted-field handling\nfunction parseCsvLine(line) {\n    const result = [];\n    let current = '';\n    let inQuotes = false;\n    for (let i = 0; i < line.length; i++) {\n        const c = line[i];\n        if (c === '\"') {\n            if (inQuotes && line[i + 1] === '\"') {\n                current += '\"';\n                i++;\n            } else {\n                inQuotes = !inQuotes;\n            }\n        } else if (c === ',' && !inQuotes) {\n            result.push(current);\n            current = '';\n        } else {\n            current += c;\n        }\n    }\n    result.push(current);\n    return result;\n}\n\nconst lines = csvText.split(/\\r?\\n/).filter(l => l.trim().length > 0);\nif (lines.length < 2) {\n    throw new Error(`CSV only has ${lines.length} lines. First 300 chars: ${csvText.substring(0, 300)}`);\n}\n\n// Parse header, fix known upstream typo\nconst rawHeaders = parseCsvLine(lines[0]).map(h => h.trim().replace(/^\"|\"$/g, ''));\nconst columnMap = { 'service_grou': 'service_groue' };\nconst headers = rawHeaders.map(h => columnMap[h] || h);\n\n// Parse rows ,  no filtering\nconst allRows = [];\nfor (let i = 1; i < lines.length; i++) {\n    const values = parseCsvLine(lines[i]);\n    const row = {};\n    headers.forEach((h, idx) => {\n        const val = (values[idx] ?? '').replace(/^\"|\"$/g, '').trim();\n        row[h] = val;\n    });\n    allRows.push(row);\n}\n\n// Dedupe on asset_id\nconst seen = new Set();\nconst deduped = [];\nfor (const row of allRows) {\n    const key = row.asset_id;\n    if (!key) continue;\n    if (seen.has(key)) continue;\n    seen.add(key);\n    deduped.push(row);\n}\n\nconsole.log(`Parsed ${allRows.length} rows, deduped to ${deduped.length}, headers: ${headers.length}`);\n\nreturn deduped.map(row => ({ json: row }));"
      },
